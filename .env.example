# ============================================================
# AI-WhaleWatcher 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=quant_loom

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=3

# --- AI / LLM (可选，不配置则跳过 AI 分析) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=

# --- 通知 (可选) ---
# 邮件
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alert@example.com
SMTP_PASSWORD=
SMTP_FROM=alert@example.com
ALERT_EMAIL_TO=admin@example.com

# 企业微信 Webhook
WECOM_WEBHOOK_URL=

# 飞书 Webhook
FEISHU_WEBHOOK_URL=

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FILE=logs/whale_watcher.log
