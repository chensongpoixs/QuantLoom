# ============================================================
# QuantLoom·量梭 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=quant_loom

# --- Celery ---
# Worker 进程就绪后是否立即排队一次全市场扫描（1=true，0=false）
CELERY_SCAN_ON_WORKER_STARTUP=true

# --- 数据源 ---
# 可选 "xtick" (推荐, 需 token) 或 "akshare" (免费, 东方财富数据)
DATA_SOURCE=xtick

# --- XTick 数据源 ---
# 在 http://www.xtick.top 注册获取 token
XTICK_TOKEN=your_xtick_token_here
XTICK_API_URL=http://api.xtick.top/doc/market

# --- AkShare 数据源 (东方财富) ---
# 免费，无需 token，但东方财富会限流。所有 QL_* 都是可选项。
# 设置 DATA_SOURCE=akshare 后启用
#
# HTTP 详细日志:
#   QL_HTTP_LOG=1                # 1=开（默认）/ 0=关
#   QL_HTTP_LOG_BODY=0           # 响应体打印长度（默认 0 不打印；800 可看 JSON 摘要）
#
# 单请求级透明重试:
#   QL_HTTP_MAX_ATTEMPTS=10      # 单个 HTTP 请求最大重试次数
#   QL_HTTP_BACKOFF_MAX=30       # 单次最长退避秒数
#
# 东方财富多 host 轮询 + ut 覆盖 (绕过限流的关键):
#   QL_EASTMONEY_HOST_ROTATE=1   # 1=失败重试时随机换 push2 子域名（默认开）
#   QL_EASTMONEY_UT=             # 自己抓包的 ut 参数（默认 ut 被滥用时手动替换）
#
# 失败兜底:
#   QL_AKSHARE_CACHE_DIR=logs/_akshare_cache    # 成功结果持久化目录
#   QL_AKSHARE_STALE_MAX_AGE=86400              # stale 快照最大可用时长（秒），默认 24h

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=3

# --- AI / LLM (可选，不配置则跳过 AI 分析) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4-0613
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- llama.cpp 本地模型 (OpenAI 兼容 HTTP API) ---
# 启动 llama-server 后，将 base_url 指向本地服务地址
# 示例: llama-server -m qwen3-32b.gguf --port 8080
#   LLAMA_BASE_URL=http://localhost:8080/v1
#   LLAMA_MODEL=qwen3-32b
#   LLAMA_API_KEY=not-needed
LLAMA_BASE_URL=
LLAMA_MODEL=
LLAMA_API_KEY=not-needed

# --- 事件抓取 (可选) ---
# 启用后，系统会从东方财富抓取新闻/公告/研报，用于事件驱动分析
EVENT_FETCH_ENABLED=True
EVENT_LOOKBACK_DAYS=3

# --- 通知 (可选) ---
# 邮件
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alert@example.com
SMTP_PASSWORD=
SMTP_FROM=alert@example.com
ALERT_EMAIL_TO=admin@example.com

# 企业微信 Webhook
WECOM_WEBHOOK_URL=

# 飞书 Webhook
FEISHU_WEBHOOK_URL=

# 钉钉 Webhook
DINGTALK_WEBHOOK_URL=

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FILE=logs/whale_watcher.log
